{
  "name": "slide-handout",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.11.0"
  },
  "scripts": {
    "dev": "pnpm --parallel -r --filter=./apps/* --filter=./convex run dev",
    "dev:web": "pnpm --filter web dev",
    "dev:convex": "pnpm --filter convex dev",
    "build": "pnpm --filter web build",
    "start": "pnpm --filter web start",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint"
  },
  "devDependencies": {
    "typescript": "^6.0.0"
  }
}
