# --- Convex ---
# From `npx convex dev` output (or Convex dashboard).
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud
# Server-only deployment-write key for ConvexHttpClient (auth route handlers).
CONVEX_DEPLOY_KEY=

# --- S3-compatible object storage (MinIO / R2 / Backblaze / AWS S3) ---
# Left empty during local-only dev; uploads will fail until configured.
S3_ENDPOINT=https://s3.example.com
S3_REGION=auto
S3_BUCKET=slide-handout-assets
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# Public-read base URL for delivered assets. Used by next/image remotePatterns.
S3_PUBLIC_BASE_URL=https://cdn.example.com/slide-handout-assets

# --- Site ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000
