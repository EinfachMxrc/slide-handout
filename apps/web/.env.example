# --- Auth.js ---
# Generate with: openssl rand -base64 32 (>= 32 chars required)
AUTH_SECRET=
# Vertrauenswürdiger Host (auto-detect in Prod wenn trustHost=true gesetzt ist,
# wir nutzen das per authConfig.trustHost).

# --- Convex ---
# From `npx convex dev` output (or Convex dashboard).
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud
# Server-only deployment-write key for ConvexHttpClient (API routes).
CONVEX_DEPLOY_KEY=

# --- S3-compatible object storage (MinIO / R2 / Backblaze / AWS S3) ---
# Die S3_*-Credentials werden im Convex-Dashboard gesetzt (server-runtime),
# NICHT in der Next.js-Env. Hier nur die öffentlichen Asset-URLs.

# Public-read base URL for delivered assets (server-side: next/image remotePatterns + CSP).
S3_PUBLIC_BASE_URL=https://cdn.example.com/slide-handout-assets
# Same URL exposed to the client (Reader rendert S3-Bilder direkt).
NEXT_PUBLIC_S3_PUBLIC_BASE_URL=https://cdn.example.com/slide-handout-assets

# --- Site ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Demo-Account (optional, defaults in env.ts) ---
# DEMO_EMAIL=demo@slide-handout.app
# DEMO_PASSWORD=slide-handout-demo-2026

# --- Sentry (optional — leer lassen deaktiviert Error-Tracking) ---
# Public DSN vom Sentry-Projekt (ungefährlich im Client-Bundle).
NEXT_PUBLIC_SENTRY_DSN=
# Environment-Label in der Sentry-UI (development | staging | production).
NEXT_PUBLIC_SENTRY_ENVIRONMENT=development
# CSP-Violation-Report-URI (Sentry → Settings → Security Header Reports).
# Leer => kein CSP-Reporting, CSP selbst bleibt aktiv.
NEXT_PUBLIC_SENTRY_CSP_REPORT_URI=
# Nur für Source-Map-Upload beim Build (Secret — nur in CI setzen).
SENTRY_AUTH_TOKEN=
SENTRY_ORG=marc-zentgraf
SENTRY_PROJECT=javascript-nextjs

# --- Build ---
# Skip env validation during Docker image build (env vars kommen zur Runtime).
# SKIP_ENV_VALIDATION=1
